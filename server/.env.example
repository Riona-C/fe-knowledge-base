# 服务端口
PORT=3000

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=root123
DB_DATABASE=fe_knowledge

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT 配置
JWT_SECRET=fe-knowledge-jwt-secret-key-2024
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# RAG Embedding（通义千问 text-embedding-v3）
RAG_EMBEDDING_MODEL=text-embedding-v3
RAG_EMBEDDING_API_KEY=your-embedding-api-key
RAG_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ChromaDB 向量库
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=fe_knowledge

# AI 大模型（通义千问 qwen-plus）
AI_MODEL_NAME=qwen-plus
AI_API_KEY=your-ai-api-key
AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 钉钉企业应用（可选）
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
DINGTALK_ROBOT_CODE=

# 文件上传
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
